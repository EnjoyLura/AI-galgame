# ======================================================================
# 图像资源声明
#
# 关键点：
#   1. 通过 config.searchpath 将 <项目根>/3_美术资源生产阶段/ 加入 Ren'Py 搜索路径。
#   2. 背景图用 Transform(fit="cover") 强制缩放到屏幕大小，避免超分辨率裁切。
#   3. 立绘方案（v2）：
#      - 所有角色表情均为完整全身立绘（表情差分/XXX/表情.png），
#        每个表情一张独立全尺寸 PNG，体态位置完全一致，
#        表情切换时不会产生像素级抖动。
#      - 底部锚点贴屏幕底部，裁切保留上半身 40%，fit="contain" 保证不裁切。
#      - 表情差分图片已统一对齐，不再做额外像素偏移补偿。
# ======================================================================

init -2 python:
    # 立绘显示用的统一转场。
    # 表情差分替换要短一点，避免同一张脸叠影太久；登场/退场可以稍柔和。
    sprite_enter = Dissolve(0.25)
    sprite_exit = Dissolve(0.20)
    sprite_expr = Dissolve(0.18)

    # 当对白写成「haru 微笑 "台词"」时，Ren'Py 会把「微笑」当作角色 image
    # attribute。这里给这类表情属性切换加一个全局短溶解，让差分替换更自然。
    config.say_attribute_transition = sprite_expr

init -1 python:
    import os

    # config.gamedir = <项目根>/5_游戏引擎与开发阶段/AI galgame/game
    # 向上三级即可抵达 <项目根>/
    _project_root = os.path.abspath(os.path.join(config.gamedir, "..", "..", ".."))
    _asset_root   = os.path.join(_project_root, "3_美术资源生产阶段")
    if os.path.isdir(_asset_root) and _asset_root not in config.searchpath:
        config.searchpath.append(_asset_root)

    # ---------------- 背景工厂 ----------------
    def _bg(file_name):
        """生成一个缩放到屏幕大小的背景 displayable。"""
        return Transform(
            "3.3_背景图/" + file_name + ".png",
            fit="cover",
            xalign=0.5, yalign=0.5,
        )

    # ---------------- 立绘工厂 ----------------
    def _sp(folder, expr):
        """
        加载完整全身立绘（表情差分图片），裁切保留上半身 40%。
        folder : 角色中文文件夹名
        expr   : 表情文件名（不含 .png）
        """
        return Transform(
            "1.1_角色立绘/表情差分/" + folder + "/" + expr + ".png",
            crop=(0.0, 0.0, 1.0, 0.4),
            crop_relative=True,
            fit="contain",
            xanchor=0.5, xalign=0.5,
            yanchor=1.0, yalign=1.0,
        )

    # ---------------- 批量注册背景 ----------------
    _bg_list = [
        # (image 名, 实际文件名)
        ("教室",         "教室"),
        ("厨房",         "厨房"),
        ("商业街",       "商业街"),
        ("图书馆",       "图书馆"),
        ("体育馆",       "体育馆"),
        ("学生会室",     "学生会室"),
        ("悠真房间白天", "悠真房间_白天"),
        ("悠真房间夜晚", "悠真房间_夜晚"),
        ("操场",         "操场"),
        ("河堤",         "河堤"),
        ("玄关",         "玄关"),
        ("走廊",         "走廊"),
        ("礼堂",         "礼堂"),
        ("樱花隧道",     "樱花隧道"),
        ("便利店",       "便利店"),
        ("天台",         "天台"),
    ]
    for _img, _file in _bg_list:
        renpy.image("bg " + _img, _bg(_file))

    # ---------------- 批量注册角色立绘 ----------------
    # 映射关系：image tag -> (角色中文文件夹, 可用表情列表)
    _char_map = {
        "haru":  ("千羽小春", ["微笑", "闭眼微笑", "正常默认", "说话", "思考", "冷淡平静", "嘟嘴", "惊讶", "害羞", "开心", "紧张", "闭眼悠闲"]),
        "chi":   ("七瀬千纱", ["正常默认", "微笑", "说话", "害羞", "紧张", "开心", "闭眼微笑", "冷淡平静", "惊讶", "感动", "嘟嘴", "闭眼悠闲", "难过失落"]),
        "aya":   ("白鸟绫音", ["正常默认", "说话", "微笑", "小恶魔浅笑", "嘟嘴", "害羞", "闭眼微笑", "认真决心", "惊讶", "难过失落"]),
        "natsu": ("星野千夏", ["正常默认", "微笑", "开心", "认真决心", "害羞", "闭眼微笑", "惊讶", "嘟嘴", "紧张", "冷淡平静", "难过失落"]),
        "aka":   ("筿崎茜",   ["正常默认", "说话", "为难", "冷淡平静", "微笑", "开心", "思考", "害羞", "认真决心", "惊讶", "闭眼微笑", "闭眼悠闲", "难过失落"]),
        "shin":  ("五十岚信", ["微笑", "思考", "惊讶", "认真决心", "说话", "闭眼微笑"]),
    }
    for _tag, (_cn, _exprs) in _char_map.items():
        for _expr in _exprs:
            renpy.image(_tag + " " + _expr, _sp(_cn, _expr))
