# ======================================================================
# 图像资源声明
#
# 关键点：
#   1. 通过 config.searchpath 将 <项目根>/3_美术资源生产阶段/ 加入 Ren'Py 搜索路径。
#   2. 背景图用 Transform(fit="cover") 强制缩放到屏幕大小，避免超分辨率裁切。
#   3. 立绘方案：
#      - 「高精度立绘/XXX_校服.png」与「表情差分/XXX/表情.png」尺寸/锚点不兼容，
#        无法自动精确合成（脸部大小和位置都对不上）。
#      - 因此暂时 **只使用高精度立绘**，并裁掉下半身保留上半身（Galgame 半身构图），
#        底部对齐屏幕底部，让下半身自然延伸到屏幕下方。
#      - 所有「tag 表情」组合目前都映射到同一张高精度立绘，保证剧本可正常跑通，
#        等后续补齐每张立绘的脸部锚点数据后再做精确合成。
# ======================================================================

init -1 python:
    import os

    # config.gamedir = <项目根>/5_游戏引擎与开发阶段/AI galgame/game
    # 向上三级即可抵达 <项目根>/
    _project_root = os.path.abspath(os.path.join(config.gamedir, "..", "..", ".."))
    _asset_root   = os.path.join(_project_root, "3_美术资源生产阶段")
    if os.path.isdir(_asset_root) and _asset_root not in config.searchpath:
        config.searchpath.append(_asset_root)

    # ---------------- 背景工厂 ----------------
    def _bg(file_name):
        """生成一个缩放到屏幕大小的背景 displayable。"""
        return Transform(
            "3.3_背景图/" + file_name + ".png",
            fit="cover",
            xalign=0.5, yalign=0.5,
        )

    # ---------------- 立绘工厂 ----------------
    def _sp(folder, expr):
        """
        只使用高精度立绘，裁掉下半身保留上半身（60%）。
        底部锚点贴屏幕底部，下半身自然延伸到屏幕下方——
        这样看起来就是标准的 Galgame 半身立绘。
        folder : 角色中文文件夹名（同时也是 _校服 前缀）
        expr   : 表情文件名（暂未使用，保留参数以便后续扩展）
        """
        return Transform(
            "1.1_角色立绘/高精度立绘/" + folder + "_校服.png",
            crop=(0.0, 0.0, 1.0, 0.6),   # 取图像从顶到 60% 高度（上半身）
            crop_relative=True,
            fit="contain",
            xalign=0.5,
            yanchor=1.0, yalign=1.0,
        )

    # ---------------- 批量注册背景 ----------------
    _bg_list = [
        # (image 名, 实际文件名)
        ("教室",         "教室"),
        ("厨房",         "厨房"),
        ("商业街",       "商业街"),
        ("图书馆",       "图书馆"),
        ("体育馆",       "体育馆"),
        ("学生会室",     "学生会室"),
        ("悠真房间白天", "悠真房间_白天"),
        ("悠真房间夜晚", "悠真房间_夜晚"),
        ("操场",         "操场"),
        ("河堤",         "河堤"),
        ("玄关",         "玄关"),
        ("走廊",         "走廊"),
    ]
    for _img, _file in _bg_list:
        renpy.image("bg " + _img, _bg(_file))

    # ---------------- 批量注册角色立绘 ----------------
    # 映射关系：image tag -> (角色中文文件夹, 可用表情列表)
    _char_map = {
        "haru":  ("千羽小春", ["嘟嘴", "害羞", "微笑", "惊讶", "正常", "紧张", "说话", "闭眼微笑", "闭眼放松"]),
        "chi":   ("七瀬千纱", ["嘟嘴", "失落", "害羞", "害羞感动", "开心", "微笑", "惊讶", "正常", "紧张", "闭眼悠闲"]),
        "aya":   ("白鸟绫音", ["为难", "嘟嘴", "害羞", "微笑", "正常", "生气", "认真决心", "说话", "闭眼笑", "难过"]),
        "natsu": ("星野千夏", ["嘟嘴", "失落不舒服", "害羞", "微笑", "惊讶", "正常", "紧张", "认真决心"]),
        "aka":   ("筿崎茜",   ["为难", "害羞", "微笑", "思考", "惊讶", "认真决心", "说话", "闭眼放松", "闭眼无表情", "难过"]),
        "shin":  ("五十岚信", ["微笑", "思考", "惊讶", "认真决心", "说话", "闭眼笑"]),
    }
    for _tag, (_cn, _exprs) in _char_map.items():
        for _expr in _exprs:
            renpy.image(_tag + " " + _expr, _sp(_cn, _expr))
