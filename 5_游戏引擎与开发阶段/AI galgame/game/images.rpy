# ======================================================================
# 图像资源声明
#
# 关键点：
#   1. 通过 config.searchpath 将 <项目根>/3_美术资源生产阶段/ 加入 Ren'Py 搜索路径。
#   2. 背景图用 Transform(fit="cover") 强制缩放到屏幕大小，避免超分辨率裁切。
#   3. 立绘方案（v2）：
#      - 所有角色表情均为完整全身立绘（表情差分/XXX/表情.png），
#        每个表情一张独立全尺寸 PNG，体态位置完全一致，
#        表情切换时不会产生像素级抖动。
#      - 底部锚点贴屏幕底部，裁切保留上半身 40%，fit="contain" 保证不裁切。
#      - _char_xoffset 表自动补偿 AI 生图导致的角色水平像素偏移，
#        确保表情切换时人物位置不抖动。
# ======================================================================

init -1 python:
    import os

    # config.gamedir = <项目根>/5_游戏引擎与开发阶段/AI galgame/game
    # 向上三级即可抵达 <项目根>/
    _project_root = os.path.abspath(os.path.join(config.gamedir, "..", "..", ".."))
    _asset_root   = os.path.join(_project_root, "3_美术资源生产阶段")
    if os.path.isdir(_asset_root) and _asset_root not in config.searchpath:
        config.searchpath.append(_asset_root)

    # ---------------- 背景工厂 ----------------
    def _bg(file_name):
        """生成一个缩放到屏幕大小的背景 displayable。"""
        return Transform(
            "3.3_背景图/" + file_name + ".png",
            fit="cover",
            xalign=0.5, yalign=0.5,
        )

    # ---------------- 人物水平偏移补偿表 ----------------
    # 以每个角色的「正常默认」表情为基准，自动计算各表情的水平像素偏移。
    # 正值 = 图片内人物偏左，Transform 向右补偿；负值反之。
    _char_xoffset = {
        "七瀬千纱": {"嘟嘴": 5.9, "害羞": 5.2, "开心": 5.2, "微笑": -9.3, "惊讶": 5.5, "感动": 1.9, "正常默认": 0.0, "紧张": 5.1, "闭眼微笑": 5.4, "闭眼悠闲": -11.5, "难过失落": -14.0},
        "五十岚信": {"微笑": 0.0, "思考": 15.6, "惊讶": 0.5, "认真决心": 9.2, "说话": 3.1, "闭眼微笑": -2.8},
        "千羽小春": {"嘟嘴": 13.5, "害羞": 13.8, "开心": 2.4, "微笑": -8.7, "思考": 3.3, "惊讶": 8.9, "正常默认": 0.0, "紧张": 10.5, "说话": -1.4, "闭眼微笑": 4.7, "闭眼悠闲": 1.0},
        "星野千夏": {"嘟嘴": 31.7, "害羞": 30.0, "开心": 13.3, "微笑": 6.0, "惊讶": 9.7, "正常默认": 0.0, "紧张": 16.0, "认真决心": 12.3, "难过失落": 20.0},
        "白鸟绫音": {"嘟嘴": 17.7, "害羞": -14.6, "微笑": -5.8, "正常默认": 0.0, "认真决心": -25.9, "说话": -7.3, "闭眼微笑": 6.3, "难过失落": -20.6},
        "筿崎茜":   {"为难": 17.3, "害羞": 3.4, "微笑": 17.1, "思考": 11.4, "惊讶": -9.0, "正常默认": 0.0, "认真决心": 7.2, "说话": 8.3, "闭眼微笑": 5.8, "闭眼悠闲": 6.7, "难过失落": 17.8},
    }

    # ---------------- 立绘工厂 ----------------
    def _sp(folder, expr):
        """
        加载完整全身立绘（表情差分图片），裁切保留上半身 40%。
        通过 _char_xoffset 自动补偿 AI 生图的人物水平偏移。
        folder : 角色中文文件夹名
        expr   : 表情文件名（不含 .png）
        """
        xoff = _char_xoffset.get(folder, {}).get(expr, 0)
        return Transform(
            "1.1_角色立绘/表情差分/" + folder + "/" + expr + ".png",
            crop=(0.0, 0.0, 1.0, 0.4),
            crop_relative=True,
            fit="contain",
            xoffset=xoff,
            xanchor=0.5, xalign=0.5,
            yanchor=1.0, yalign=1.0,
        )

    # ---------------- 批量注册背景 ----------------
    _bg_list = [
        # (image 名, 实际文件名)
        ("教室",         "教室"),
        ("厨房",         "厨房"),
        ("商业街",       "商业街"),
        ("图书馆",       "图书馆"),
        ("体育馆",       "体育馆"),
        ("学生会室",     "学生会室"),
        ("悠真房间白天", "悠真房间_白天"),
        ("悠真房间夜晚", "悠真房间_夜晚"),
        ("操场",         "操场"),
        ("河堤",         "河堤"),
        ("玄关",         "玄关"),
        ("走廊",         "走廊"),
        ("礼堂",         "礼堂"),
        ("樱花隧道",     "樱花隧道"),
        ("便利店",       "便利店"),
        ("天台",         "天台"),
    ]
    for _img, _file in _bg_list:
        renpy.image("bg " + _img, _bg(_file))

    # ---------------- 批量注册角色立绘 ----------------
    # 映射关系：image tag -> (角色中文文件夹, 可用表情列表)
    _char_map = {
        "haru":  ("千羽小春", ["嘟嘴", "害羞", "开心", "微笑", "思考", "惊讶", "正常默认", "紧张", "说话", "闭眼微笑", "闭眼悠闲"]),
        "chi":   ("七瀬千纱", ["嘟嘴", "害羞", "开心", "微笑", "惊讶", "感动", "正常默认", "紧张", "闭眼微笑", "闭眼悠闲", "难过失落"]),
        "aya":   ("白鸟绫音", ["嘟嘴", "害羞", "微笑", "正常默认", "认真决心", "说话", "闭眼微笑", "难过失落"]),
        "natsu": ("星野千夏", ["嘟嘴", "害羞", "开心", "微笑", "惊讶", "正常默认", "紧张", "认真决心", "难过失落"]),
        "aka":   ("筿崎茜",   ["为难", "害羞", "微笑", "思考", "惊讶", "正常默认", "认真决心", "说话", "闭眼微笑", "闭眼悠闲", "难过失落"]),
        "shin":  ("五十岚信", ["微笑", "思考", "惊讶", "认真决心", "说话", "闭眼微笑"]),
    }
    for _tag, (_cn, _exprs) in _char_map.items():
        for _expr in _exprs:
            renpy.image(_tag + " " + _expr, _sp(_cn, _expr))
