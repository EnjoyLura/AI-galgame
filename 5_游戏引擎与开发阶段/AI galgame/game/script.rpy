# ======================================================================
# 《君と描くパレット》主剧本 — 入口文件
# ======================================================================
#
# 剧本文件组织结构：
#   scripts/common/     共通线（按章节拆分）
#     chapter01.rpy     第一章：局外人的春天（4月）
#     chapter02.rpy     第二章：色彩的觉醒（5月）
#     chapter03.rpy     第三章：交错的心意（6月）
#     chapter04.rpy     第四章：分岐之夜（7月上旬 / 烟花大会）
#   scripts/routes/     个人线（按角色拆分）
#     ayane.rpy         绫音线 ——「傲娇的调色盘」
#     chinatsu.rpy      千夏线 ——「阳光下的影子」
#     chisa.rpy         千纱线 ——「七年的距离」（官方女主）
#     akane.rpy         茜线 ——「便利店暖光」
#     koharu.rpy        小春线 ——「铃兰的告白」
#
# 角色定义见 characters.rpy
# 图像资源声明见 images.rpy
# ======================================================================


# ======================================================================
# 游戏全局变量（Flag 系统）
# ======================================================================

# 角色好感 Flag（共通线中通过关键选择获取）
default FLAG_AYANE = False      # 绫音线准入Flag
default FLAG_CHINATSU = False   # 千夏线准入Flag
default FLAG_CHISA = False      # 千纱线准入Flag
default FLAG_AKANE = False      # 茜线准入Flag
default FLAG_KOHARU = 0         # 小春线准入Flag（计数器：周末在家次数）

# 玩家选择的路线（烟花大会时设定）
default selected_route = ""


# ======================================================================
# 游戏开始
# ======================================================================

label start:

    scene black with fade

    "——四月，樱花盛开的季节。"
    "新学期，新班级。"
    "一切都像被重新粉刷过的墙壁，干净而陌生。"

    jump c01_s001_yuma_room_wakeup
